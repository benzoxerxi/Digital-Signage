# Digital Signage SaaS - Environment Variables
# Copy this file to .env and fill in your actual values.
#
# WHERE TO ADD THESE:
# - Local:  Copy to .env in this folder (digital-signage-saas). Never commit .env.
# - Render: Dashboard → Your Web Service → Environment → Add each variable there.

# Flask Secret Key (Generate a random secure key)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Admin Bootstrap (one-time: create admin on Render)
# Set a random token, visit /admin/bootstrap?token=YOUR_TOKEN, then remove this env var
# ADMIN_BOOTSTRAP_TOKEN=your-secret-token-here

# Database URL (REQUIRED in production so users/data persist across deploys)
# Local: leave unset to use SQLite, or set for Postgres
# Render/Heroku: add a PostgreSQL service and set DATABASE_URL (auto-set when linked)
# For PostgreSQL: postgresql://username:password@host/dbname
# DATABASE_URL=sqlite:///signage.db

# Google Drive (OAuth – get from https://console.cloud.google.com/ → APIs & Services → Credentials)
# Create OAuth 2.0 Client ID (Web application), add redirect URI below to Authorized redirect URIs.
GOOGLE_DRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
# Production: https://your-app.onrender.com/api/auth/google/drive/callback
# Local:      http://127.0.0.1:5000/api/auth/google/drive/callback
GOOGLE_DRIVE_REDIRECT_URI=

# Stripe API Keys (Get from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration (for verification emails; optional)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=your-email@gmail.com
