# /etc/nginx/sites-available/signage  → symlink to sites-enabled
# Replace server_name and ssl_certificate paths after certbot.
# Upstream must match gunicorn bind (127.0.0.1:8000).

upstream signage_app {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name 94.250.201.69;   # or your domain

    client_max_body_size 500M;

    location / {
        proxy_pass http://signage_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_buffering on;
        proxy_buffers 16 16k;
        proxy_busy_buffers_size 32k;
        proxy_request_buffering on;
    }
}
