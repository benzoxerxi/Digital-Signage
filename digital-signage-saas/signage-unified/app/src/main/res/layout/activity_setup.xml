<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/karcher_yellow">

    <include
        layout="@layout/notification_header"
        android:id="@+id/notification_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="0dp"
        android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/logo_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="0dp"
        android:visibility="gone"
        android:scaleType="fitCenter"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Digital Signage Player"
        android:textSize="20sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginBottom="0dp"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configure your connection"
        android:textSize="13sp"
        android:textColor="#000000"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/server_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Server Address"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/server_input"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="https://benzos.uk/signage"
                    android:inputType="textUri"
                    android:padding="12dp"
                    android:background="@drawable/input_background"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Change only if using a different server"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="9-Digit Connection Code"
                android:textSize="13sp"
                android:textColor="#666666"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:gravity="center" />

            <EditText
                android:id="@+id/connection_code_input"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="847291536"
                android:inputType="number"
                android:maxLength="9"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="17sp"
                android:textColor="#000000"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter your 9-digit code from Account settings"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginTop="4dp"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Screen name"
                android:textSize="13sp"
                android:textColor="#666666"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:gravity="center" />

            <EditText
                android:id="@+id/device_name_input"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="My Screen"
                android:inputType="text"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This name will appear in the control panel"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginTop="4dp"
                android:gravity="center" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/connect_button"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="CONNECT"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="#000000"
        android:textColor="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Get your code from Account on the website."
        android:textSize="11sp"
        android:textColor="#000000"
        android:layout_marginTop="6dp"
        android:gravity="center" />

    </LinearLayout>

    </ScrollView>

</LinearLayout>
